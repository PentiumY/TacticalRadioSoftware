<Window
    x:Class="TacticalRadio.Launcher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Tactical Radio">

    <Grid x:Name="RootGrid" Background="#F6F8FB">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="ResponsiveStates">

                <VisualState x:Name="NarrowLayout" />

                <VisualState x:Name="MediumLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="720" />
                    </VisualState.StateTriggers>

                    <VisualState.Setters>
                        <Setter Target="PlaceJobSecondColumn.Width" Value="*" />
                        <Setter Target="JobIdPanel.(Grid.Row)" Value="0" />
                        <Setter Target="JobIdPanel.(Grid.Column)" Value="1" />

                        <Setter Target="MumbleBrowseColumn.Width" Value="110" />
                        <Setter Target="BrowseButton.(Grid.Row)" Value="0" />
                        <Setter Target="BrowseButton.(Grid.Column)" Value="1" />

                        <Setter Target="ButtonColumn2.Width" Value="*" />
                        <Setter Target="ButtonColumn3.Width" Value="0" />

                        <Setter Target="SaveSettingsButton.(Grid.Row)" Value="0" />
                        <Setter Target="SaveSettingsButton.(Grid.Column)" Value="0" />
                        <Setter Target="SaveSettingsButton.(Grid.ColumnSpan)" Value="1" />

                        <Setter Target="RepairPluginButton.(Grid.Row)" Value="0" />
                        <Setter Target="RepairPluginButton.(Grid.Column)" Value="1" />
                        <Setter Target="RepairPluginButton.(Grid.ColumnSpan)" Value="1" />

                        <Setter Target="LaunchMumbleButton.(Grid.Row)" Value="1" />
                        <Setter Target="LaunchMumbleButton.(Grid.Column)" Value="0" />
                        <Setter Target="LaunchMumbleButton.(Grid.ColumnSpan)" Value="2" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="WideLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="940" />
                    </VisualState.StateTriggers>

                    <VisualState.Setters>
                        <Setter Target="PlaceJobSecondColumn.Width" Value="*" />
                        <Setter Target="JobIdPanel.(Grid.Row)" Value="0" />
                        <Setter Target="JobIdPanel.(Grid.Column)" Value="1" />

                        <Setter Target="MumbleBrowseColumn.Width" Value="110" />
                        <Setter Target="BrowseButton.(Grid.Row)" Value="0" />
                        <Setter Target="BrowseButton.(Grid.Column)" Value="1" />

                        <Setter Target="ButtonColumn2.Width" Value="*" />
                        <Setter Target="ButtonColumn3.Width" Value="*" />

                        <Setter Target="SaveSettingsButton.(Grid.Row)" Value="0" />
                        <Setter Target="SaveSettingsButton.(Grid.Column)" Value="0" />
                        <Setter Target="SaveSettingsButton.(Grid.ColumnSpan)" Value="1" />

                        <Setter Target="RepairPluginButton.(Grid.Row)" Value="0" />
                        <Setter Target="RepairPluginButton.(Grid.Column)" Value="1" />
                        <Setter Target="RepairPluginButton.(Grid.ColumnSpan)" Value="1" />

                        <Setter Target="LaunchMumbleButton.(Grid.Row)" Value="0" />
                        <Setter Target="LaunchMumbleButton.(Grid.Column)" Value="2" />
                        <Setter Target="LaunchMumbleButton.(Grid.ColumnSpan)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Background="White"
            BorderBrush="#E3E8EF"
            BorderThickness="0,0,0,1">

            <Grid Padding="24,22,24,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Width="56"
                    Height="56"
                    Background="#F1F5F9"
                    CornerRadius="14"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

                    <Grid>
                        <Image
                            x:Name="LogoImage"
                            Width="44"
                            Height="44"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Stretch="Uniform" />

                        <TextBlock
                            x:Name="LogoFallbackText"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="#1E293B"
                            Text="TR" />
                    </Grid>
                </Border>

                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Spacing="5">

                    <TextBlock
                        FontSize="26"
                        FontWeight="SemiBold"
                        Foreground="#111827"
                        Text="Tactical Radio"
                        TextWrapping="Wrap" />

                    <TextBlock
                        FontSize="14"
                        Foreground="#64748B"
                        Text="Configure the bridge connection, install the Mumble plugin, and launch Mumble."
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">

            <Grid
                Padding="24,20,24,18"
                HorizontalAlignment="Stretch">

                <Grid
                    HorizontalAlignment="Stretch"
                    MaxWidth="1120">

                    <StackPanel Spacing="14">

                        <Border
                            x:Name="UpdateCard"
                            Background="White"
                            BorderBrush="#E3E8EF"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20,18,20,20">

                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="#111827"
                                        Text="Software update" />

                                    <TextBlock
                                        x:Name="UpdateStatusTitleText"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="#334155"
                                        Text="Checking for updates..." />

                                    <TextBlock
                                        x:Name="UpdateStatusMessageText"
                                        FontSize="12"
                                        Foreground="#64748B"
                                        Text="Using GitHub Releases as the source of truth."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <Grid
                                    Grid.Row="1"
                                    ColumnSpacing="10">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button
                                        x:Name="CheckForUpdatesButton"
                                        Grid.Column="0"
                                        MinHeight="38"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch"
                                        Click="CheckForUpdatesButton_Click"
                                        Content="Check again" />

                                    <Button
                                        x:Name="UpdateButton"
                                        Grid.Column="1"
                                        MinHeight="38"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch"
                                        Click="UpdateButton_Click"
                                        Content="Checking..."
                                        IsEnabled="False" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border
                            Background="White"
                            BorderBrush="#E3E8EF"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20,18,20,20">

                            <StackPanel Spacing="14">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="#111827"
                                    Text="Bridge settings" />

                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Foreground="#334155"
                                        Text="Base URL" />

                                    <TextBox
                                        x:Name="BaseUrlTextBox"
                                        MinHeight="36"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch"
                                        PlaceholderText="https://your-bridge-server.example" />

                                    <TextBlock
                                        Margin="0,2,0,4"
                                        FontSize="12"
                                        Foreground="#64748B"
                                        Text="Optional. Leave empty to avoid shipping a default server address."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <Grid
                                    x:Name="PlaceJobGrid"
                                    ColumnSpacing="14"
                                    RowSpacing="12">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="PlaceJobFirstColumn" Width="*" />
                                        <ColumnDefinition x:Name="PlaceJobSecondColumn" Width="0" />
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel
                                        x:Name="PlaceIdPanel"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Spacing="4">

                                        <TextBlock
                                            Foreground="#334155"
                                            Text="Place ID" />

                                        <TextBox
                                            x:Name="PlaceIdTextBox"
                                            MinHeight="36"
                                            MinWidth="0"
                                            HorizontalAlignment="Stretch" />
                                    </StackPanel>

                                    <StackPanel
                                        x:Name="JobIdPanel"
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Spacing="4">

                                        <TextBlock
                                            Foreground="#334155"
                                            Text="Job ID" />

                                        <TextBox
                                            x:Name="JobIdTextBox"
                                            MinHeight="36"
                                            MinWidth="0"
                                            HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock
                                    FontSize="12"
                                    Foreground="#64748B"
                                    Text="These values are passed to Mumble as TRADIO_PLACE_ID and TRADIO_JOB_ID."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Border
                            Background="White"
                            BorderBrush="#E3E8EF"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20,18,20,20">

                            <StackPanel Spacing="14">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="#111827"
                                    Text="Mumble" />

                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Foreground="#334155"
                                        Text="Mumble path" />

                                    <Grid
                                        x:Name="MumblePathGrid"
                                        ColumnSpacing="12"
                                        RowSpacing="10">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition x:Name="MumbleBrowseColumn" Width="0" />
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBox
                                            x:Name="MumblePathTextBox"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            MinHeight="36"
                                            MinWidth="0"
                                            HorizontalAlignment="Stretch" />

                                        <Button
                                            x:Name="BrowseButton"
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            MinHeight="36"
                                            MinWidth="0"
                                            HorizontalAlignment="Stretch"
                                            Click="BrowseButton_Click"
                                            Content="Browse" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid
                            x:Name="ButtonGrid"
                            ColumnSpacing="12"
                            RowSpacing="10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="ButtonColumn1" Width="*" />
                                <ColumnDefinition x:Name="ButtonColumn2" Width="0" />
                                <ColumnDefinition x:Name="ButtonColumn3" Width="0" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Button
                                x:Name="SaveSettingsButton"
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="1"
                                MinHeight="42"
                                MinWidth="0"
                                HorizontalAlignment="Stretch"
                                Click="SaveSettingsButton_Click"
                                Content="Save Settings" />

                            <Button
                                x:Name="RepairPluginButton"
                                Grid.Row="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="1"
                                MinHeight="42"
                                MinWidth="0"
                                HorizontalAlignment="Stretch"
                                Click="RepairPluginButton_Click"
                                Content="Install / Repair" />

                            <Button
                                x:Name="LaunchMumbleButton"
                                Grid.Row="2"
                                Grid.Column="0"
                                Grid.ColumnSpan="1"
                                MinHeight="42"
                                MinWidth="0"
                                HorizontalAlignment="Stretch"
                                Click="LaunchMumbleButton_Click"
                                Content="Launch Mumble" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border
            Grid.Row="2"
            Background="#F6F8FB"
            Padding="24,0,24,20">

            <InfoBar
                x:Name="StatusInfoBar"
                HorizontalAlignment="Stretch"
                MaxWidth="1120"
                IsClosable="False"
                IsOpen="True"
                Message="Base URL is empty by default."
                Severity="Informational"
                Title="Ready" />
        </Border>
    </Grid>
</Window>